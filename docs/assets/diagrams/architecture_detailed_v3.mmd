%% Campus RAG Assistant — detailed architecture (v3)
%% Source of truth for `architecture_detailed_v3`. Render inline via mkdocs
%% (pymdownx.snippets in a ```mermaid fence) or to PNG via mermaid-cli:
%%   mmdc -i architecture_detailed_v3.mmd -o architecture_detailed_v3.png
flowchart TB
  User((User))

  subgraph FE ["Frontend"]
    direction LR
    Vue["Vue 3 SPA<br/>SSE · OAuth handoff"]
    Streamlit["Streamlit (optional)"]
  end

  Edge["Edge · Infra<br/>Nginx · Elastic Beanstalk · Terraform"]

  API["FastAPI<br/>/api/auth · /api/chat ·<br/>/api/helpdesk · /api/helpdesk/agent · /api/metrics"]

  subgraph AI ["AI &amp; Agents"]
    direction TB
    RAG["LangGraph RAG<br/>condense → multi_query → retrieve → rerank → generate → format"]
    Help["Helpdesk Agent (bounded)<br/>Supervisor · Clarifier · Classifier · Writer"]
    Tools["Agent Tools<br/>retry_kb · web_search · search_dups · file_ticket"]
    Reg["Provider Registry"]
  end

  subgraph Prov ["Providers"]
    direction LR
    AWS["AWS<br/>Bedrock LLM ·<br/>Bedrock KB ·<br/>OpenSearch Serverless"]
    Azure["Azure<br/>OpenAI ·<br/>AI Search"]
    Mock["Local / CI<br/>Mock LLM + retriever<br/>(RAG_FORCE_MOCK)"]
  end

  subgraph Ext ["External Services"]
    direction LR
    GH["GitHub Issues<br/>HITL ticket target"]
    Web["Tavily · Web search"]
  end

  subgraph Data ["Data &amp; Observability"]
    direction LR
    PG[("PostgreSQL<br/>users · sessions ·<br/>tenant.rag_config")]
    SQLite[("SQLite Checkpointer<br/>agent state · 24h TTL")]
    Prom["Prometheus"]
    LS["LangSmith"]
    RAGAS["RAGAS eval"]
  end

  %% Top-to-bottom flow: User → Frontend → Edge → API
  User --> Vue
  Vue -->|REST + SSE| Edge
  Streamlit -.same API.-> Edge
  Edge --> API

  %% API → AI / Data
  API -->|stream_query| RAG
  API --> Help
  API -->|sessions / auth| PG

  %% RAG → escalation → Helpdesk
  RAG -.kb_resolved=false.-> Help
  Help --> Tools
  Help -->|state| SQLite

  %% AI → Providers
  RAG --> Reg
  Tools --> Reg
  Reg --> AWS
  Reg --> Azure
  Reg --> Mock

  %% Tools → External (HITL + web)
  Tools -.HITL gate.-> GH
  Tools -.web_search.-> Web

  %% Observability
  RAG -.traces.-> LS
  Help -.traces.-> LS
  API --> Prom
  RAGAS -.golden_dataset.-> RAG
