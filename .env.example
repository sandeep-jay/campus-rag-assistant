# =============================================================================
# Campus RAG Assistant — environment template
# =============================================================================
# Copy to `.env` in the repo root and fill in values.
# Loaded by backend/app/core/config_manager.py (also reads `.env.{APP_ENV}` if present).
#
# Quick start (no cloud): use the "Mock RAG demo" block at the bottom.
# Production / cloud RAG: set LLM_PROVIDER + RETRIEVER_PROVIDER to aws or azure.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# development | test | production
ENVIRONMENT=development

# Selects layered config file `.env.{APP_ENV}` when present (e.g. `.env.development`)
APP_ENV=development

# Change in production (generate a strong random value)
SECRET_KEY=change-me-in-production

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# SQLAlchemy URL used by the API and Alembic
DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot_dev

# Used by some test scripts (optional)
# POSTGRES_DB=chatbot_dev

# -----------------------------------------------------------------------------
# API, CORS, and frontends
# -----------------------------------------------------------------------------
# Vue dev server (Vite) — also set VITE_API_URL in frontend-vue/.env.local
FRONTEND_URL=http://localhost:5173

# Comma-separated allowed origins, or * for local dev (see backend CORS logic)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Streamlit client / scripts (optional)
API_URL=http://localhost:8000

# JWT lifetime (minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=240

# -----------------------------------------------------------------------------
# RAG providers
# -----------------------------------------------------------------------------
# Force mock LLM + retriever regardless of provider vars (good for local demo / CI unit tests)
# true | false
RAG_FORCE_MOCK=false

# LLM backend: mock | aws | azure
LLM_PROVIDER=mock

# Retriever backend: mock | aws | azure
RETRIEVER_PROVIDER=mock

# Optional shortcut: sets BOTH when LLM_PROVIDER and RETRIEVER_PROVIDER are unset
# mock | aws | azure
# RAG_PROVIDER=

# When LLM_PROVIDER and RETRIEVER_PROVIDER are both set, they override RAG_PROVIDER.

# -----------------------------------------------------------------------------
# AWS — Bedrock LLM + Knowledge Base (LLM_PROVIDER=aws, RETRIEVER_PROVIDER=aws)
# -----------------------------------------------------------------------------
AWS_REGION=us-west-2

# Optional: named profile from ~/.aws/credentials (local dev)
AWS_PROFILE_NAME=default

# Optional: explicit keys (otherwise default AWS credential chain / SSO)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Recommended for deployed environments (assumes role instead of long-lived keys)
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/your-role-name

# Bedrock chat model (must match your account / region)
# Use a current on-demand model in your region (claude-v2 / claude-instant are EOL)
# Or set anthropic.claude-3-5-haiku-... (auto-prefixed to us./eu. profile)
# Examples: anthropic.claude-3-5-haiku-20241022-v1:0, anthropic.claude-3-5-sonnet-20240620-v1:0
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# Bedrock Knowledge Base ID (not a placeholder in real deployments)
BEDROCK_KNOWLEDGE_BASE_ID=your_knowledge_base_id

# Embeddings for Azure-style hybrid search N/A on AWS KB; used by RAGAS eval judge on aws
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1

# -----------------------------------------------------------------------------
# Azure OpenAI — chat LLM (LLM_PROVIDER=azure)
# -----------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=your-chat-deployment
# AZURE_OPENAI_API_VERSION=2024-02-01

# -----------------------------------------------------------------------------
# Azure AI Search + embeddings (RETRIEVER_PROVIDER=azure)
# -----------------------------------------------------------------------------
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
# AZURE_SEARCH_SERVICE_NAME=your-search-service
# AZURE_SEARCH_KEY=
# AZURE_SEARCH_INDEX=your-index-name

# -----------------------------------------------------------------------------
# LLM and retrieval tuning
# -----------------------------------------------------------------------------
TEMPERATURE=0.1
MAX_TOKENS=500
TOP_K=10

# Number of documents retrieved per query
RETRIEVER_NUMBER_OF_RESULTS=3

# AWS KB / Azure search mode where applicable: HYBRID | SEMANTIC | VECTOR
RETRIEVER_SEARCH_TYPE=HYBRID

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# DEBUG | INFO | WARNING | ERROR
LOGGING_LEVEL=INFO

LOG_TO_FILE=true
LOGGING_LOCATION=backend_logs.log
LOGGING_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s [in %(pathname)s:%(lineno)d]"
LOGGING_PROPAGATION_LEVEL=INFO

# Structured JSON logs (optional)
# LOG_JSON=false

# -----------------------------------------------------------------------------
# LangSmith — tracing (optional)
# -----------------------------------------------------------------------------
LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=campus-rag-assistant
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
# true | false (process-local windows; use REDIS_URL for multi-instance production)
RATE_LIMIT_ENABLED=true

RATE_LIMIT_LOGIN_PER_MINUTE=10
RATE_LIMIT_REGISTER_PER_MINUTE=5
RATE_LIMIT_CHAT_PER_MINUTE=30

# Optional: shared Redis for rate limits across API workers
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# API behavior (production defaults are stricter)
# -----------------------------------------------------------------------------
# Expose /api/auth/debug-auth and /api/chat/test_langsmith
# ENABLE_DEV_API_ROUTES=true

# Swagger / ReDoc / OpenAPI JSON
# ENABLE_OPENAPI_DOCS=true

# -----------------------------------------------------------------------------
# RAGAS quality eval (optional — `tox -e eval` / pytest -m slow)
# -----------------------------------------------------------------------------
# Judge LLM for metrics; defaults to LLM_PROVIDER. Use aws or azure (not mock).
# RAGAS_LLM_PROVIDER=aws

# Enforce score thresholds (usually nightly / release, not PR CI)
# RAGAS_QUALITY_GATE=0

# Minimum scores (0.0–1.0) when RAGAS_QUALITY_GATE=1
# RAGAS_FAITHFULNESS_MIN=0.85
# RAGAS_ANSWER_RELEVANCY_MIN=0.80
# RAGAS_CONTEXT_RECALL_MIN=0.75
# RAGAS_CONTEXT_PRECISION_MIN=0.70

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
# Set true in automated test environments only
TESTING=false

# =============================================================================
# Mock RAG demo (no AWS / Azure credentials required)
# =============================================================================
# Uncomment this block for the README quick start:
#
# RAG_FORCE_MOCK=true
# LLM_PROVIDER=mock
# RETRIEVER_PROVIDER=mock
# DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot_dev
