# =============================================================================
# Campus RAG Assistant — environment template
# =============================================================================
# Copy this file to `.env` in the repo root and fill in real values.
# Loaded by backend/app/core/config_manager.py (which also reads
# `.env.{APP_ENV}` when present, e.g. `.env.development`).
#
# Legend:
#   [REQUIRED]                always set
#   [REQUIRED IF <cond>]      set when the named feature/provider is active
#   [OPTIONAL — default: <v>] the code default is shown; uncomment to override
#
# Quick start (no cloud):    use the "Mock RAG demo" block at the bottom.
# Production / cloud RAG:    set LLM_PROVIDER + RETRIEVER_PROVIDER to aws or
#                            azure and provide the matching credentials.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Core application                                                  [REQUIRED]
# -----------------------------------------------------------------------------
# [REQUIRED] development | test | production
# Selects the layered config file `.env.{APP_ENV}` when present.
APP_ENV=development

# [REQUIRED in production] JWT/session signing key.
# The placeholder below is a sentinel — startup checks reject it in prod.
SECRET_KEY=change-me-in-production

# [OPTIONAL — default: 'EdTech RAG Assistant API']
# PROJECT_NAME=EdTech RAG Assistant API
# [OPTIONAL — default: '1.0.0']
# VERSION=1.0.0
# [OPTIONAL — default: '/api']
# API_V1_STR=/api
# [OPTIONAL — default: 'HS256']  JWT signing algorithm.
# ALGORITHM=HS256


# -----------------------------------------------------------------------------
# 2. Database (PostgreSQL)                                             [REQUIRED]
# -----------------------------------------------------------------------------
# [REQUIRED] SQLAlchemy URL used by the API and Alembic.
DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot_dev

# [OPTIONAL] Used by a few test helpers.
# POSTGRES_DB=chatbot_dev

# [OPTIONAL — default: 5]
SQLALCHEMY_POOL_SIZE=5
# [OPTIONAL — default: 10]
SQLALCHEMY_MAX_OVERFLOW=10

# [DERIVED — do not set; built from DATABASE_URL by assemble_db_connection()]
# SQLALCHEMY_DATABASE_URI=


# -----------------------------------------------------------------------------
# 3. API, CORS, and frontends                                          [REQUIRED]
# -----------------------------------------------------------------------------
# [REQUIRED] Vue dev URL (host must match the browser URL — note that
# localhost ≠ 127.0.0.1 for cookies).
FRONTEND_URL=http://127.0.0.1:5173

# [REQUIRED] Comma-separated allowed origins, or * for local dev (see backend
# CORS logic).
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# [REQUIRED for Streamlit frontend]
API_URL=http://localhost:8000

# [OPTIONAL — default: 240]
ACCESS_TOKEN_EXPIRE_MINUTES=240


# -----------------------------------------------------------------------------
# 4. RAG providers                                                     [REQUIRED]
# -----------------------------------------------------------------------------
# [OPTIONAL — default: false]  Force the mock RAG demo even if a real
# provider is configured (useful for screen-recordings / local dev).
RAG_FORCE_MOCK=false

# [REQUIRED] mock | aws | azure
LLM_PROVIDER=mock
# [REQUIRED] mock | aws | azure
RETRIEVER_PROVIDER=mock

# [OPTIONAL] Shorthand: setting RAG_PROVIDER overrides both LLM_PROVIDER and
# RETRIEVER_PROVIDER. Leave commented to set them independently.
# RAG_PROVIDER=


# -----------------------------------------------------------------------------
# 5. AWS (Bedrock + Bedrock Knowledge Base)                  [REQUIRED IF aws]
# -----------------------------------------------------------------------------
# [REQUIRED IF LLM_PROVIDER=aws or RETRIEVER_PROVIDER=aws]
AWS_REGION=us-west-2

# [OPTIONAL — default: 'default']  Named profile to read from ~/.aws/credentials.
AWS_PROFILE_NAME=default

# [OPTIONAL] Static keys — prefer instance profiles / IRSA in prod.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# [OPTIONAL] Assume-role ARN for cross-account access.
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/your-role-name

# [REQUIRED IF LLM_PROVIDER=aws] Bedrock chat model.
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-haiku-20241022-v1:0

# [REQUIRED IF RETRIEVER_PROVIDER=aws]
BEDROCK_KNOWLEDGE_BASE_ID=your_knowledge_base_id

# [OPTIONAL — default: 'amazon.titan-embed-text-v1']
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v1


# -----------------------------------------------------------------------------
# 6. Azure (OpenAI + Azure AI Search)                      [REQUIRED IF azure]
# -----------------------------------------------------------------------------
# [REQUIRED IF LLM_PROVIDER=azure or RETRIEVER_PROVIDER=azure]
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=your-chat-deployment
# AZURE_OPENAI_API_VERSION=2024-02-01

# [REQUIRED IF RETRIEVER_PROVIDER=azure]
# AZURE_EMBEDDING_DEPLOYMENT=text-embedding-ada-002
# AZURE_SEARCH_SERVICE_NAME=your-search-service
# AZURE_SEARCH_KEY=
# AZURE_SEARCH_INDEX=your-index-name

# [OPTIONAL — default: 'text_vector']  Index field holding embedding vectors.
# AZURE_SEARCH_VECTOR_FIELD=text_vector


# -----------------------------------------------------------------------------
# 7. RAG behaviour                                                   [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL — default: 0.1]
TEMPERATURE=0.1
# [OPTIONAL — default: 500]
MAX_TOKENS=500
# [OPTIONAL — default: 10]
TOP_K=10

# [OPTIONAL — default: 3]   Number of documents returned by the retriever.
RETRIEVER_NUMBER_OF_RESULTS=3
# [OPTIONAL — default: 'HYBRID']  Retriever search mode.
RETRIEVER_SEARCH_TYPE=HYBRID


# -----------------------------------------------------------------------------
# 8. Logging                                                         [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL — default: 'INFO']
LOGGING_LEVEL=INFO
# [OPTIONAL — default: true]
LOG_TO_FILE=true
# [OPTIONAL — default: 'backend_logs.log']
LOGGING_LOCATION=backend_logs.log
# [OPTIONAL]
LOGGING_FORMAT="[%(asctime)s] req=%(request_id)s - %(levelname)s: %(message)s [in %(pathname)s:%(lineno)d]"
# [OPTIONAL — default: 'INFO']
LOGGING_PROPAGATION_LEVEL=INFO

# [OPTIONAL — default: false]  Emit one JSON object per line.
# LOG_JSON=false


# -----------------------------------------------------------------------------
# 9. LangSmith tracing                                               [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL — default: false]
LANGCHAIN_TRACING_V2=false
# [REQUIRED IF LANGCHAIN_TRACING_V2=true]
# LANGCHAIN_API_KEY=
# [OPTIONAL — default: 'campus-rag-assistant']
LANGCHAIN_PROJECT=campus-rag-assistant
# [OPTIONAL — default: 'https://api.smith.langchain.com']
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com


# -----------------------------------------------------------------------------
# 10. Rate limiting                                                  [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL — default: true]
RATE_LIMIT_ENABLED=true
# [OPTIONAL — default: 10]
RATE_LIMIT_LOGIN_PER_MINUTE=10
# [OPTIONAL — default: 5]
RATE_LIMIT_REGISTER_PER_MINUTE=5
# [OPTIONAL — default: 30]
RATE_LIMIT_CHAT_PER_MINUTE=30

# [OPTIONAL] Use Redis for distributed rate limit state.
# REDIS_URL=redis://localhost:6379/0


# -----------------------------------------------------------------------------
# 11. Assistant persona                                              [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL]
ASSISTANT_NAME=EdTech Support Assistant
# [OPTIONAL]
SUPPORTED_TOPICS=your learning platform, course tools, integrations, and support documentation
# [OPTIONAL]
OUT_OF_SCOPE_MESSAGE=I can only answer questions covered by the knowledge base for {{supported_topics}}. Please ask a question related to those topics.

# [OPTIONAL — default: 40]
CHAT_HISTORY_MAX_MESSAGES=40
# [OPTIONAL — default: 0]   Streaming delay (ms) to simulate slower LLMs.
STREAM_ARTIFICIAL_DELAY_MS=0


# -----------------------------------------------------------------------------
# 12. Runtime / server                                               [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL]  Uvicorn worker count for prod.
# API_WORKERS=2
# UVICORN_WORKERS=4

# [OPTIONAL — default: undefined; treated as false in prod]  Expose
# /api/auth/debug-auth and /api/chat/test_langsmith.
# ENABLE_DEV_API_ROUTES=true

# [OPTIONAL — default: undefined; treated as false in prod]  Expose
# Swagger / ReDoc / OpenAPI JSON.
# ENABLE_OPENAPI_DOCS=true


# -----------------------------------------------------------------------------
# 13. RAGAS evaluation                                               [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL]
# RAGAS_LLM_PROVIDER=aws

# [OPTIONAL]
# RAGAS_QUALITY_GATE=0

# [OPTIONAL] Per-metric thresholds for the RAGAS quality gate.
# RAGAS_FAITHFULNESS_MIN=0.85
# RAGAS_ANSWER_RELEVANCY_MIN=0.80
# RAGAS_CONTEXT_RECALL_MIN=0.75
# RAGAS_CONTEXT_PRECISION_MIN=0.70


# -----------------------------------------------------------------------------
# 14. Retrieval features                                             [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL — default: false]   Multi-query expansion at retrieval time.
MULTI_QUERY_ENABLED=false
# [OPTIONAL — default: 2]
MULTI_QUERY_COUNT=2

# [OPTIONAL — default: false]  Server-side metadata filter.
METADATA_FILTER_ENABLED=false
# METADATA_FILTER_JSON={"equals": {"key": "your-metadata-key", "value": "your-value"}}
# [OPTIONAL — default: false]  Client-side metadata filter.
METADATA_FILTER_CLIENT_ENABLED=false
# METADATA_FILTER_CLIENT_JSON={"project": "web-research"}

# [OPTIONAL — default: false]  Re-rank retrieved documents.
RERANK_ENABLED=false
# [OPTIONAL]  'flashrank' or 'keyword'.
# RERANK_BACKEND=flashrank
# [OPTIONAL — default: 3]
RERANK_TOP_N=3
# [OPTIONAL — default: 10]
RERANK_CANDIDATE_K=10
# [OPTIONAL — default: 10]
RERANK_PREFILTER_MAX=10
# [OPTIONAL — default: 0]
RERANK_MIN_KEYWORD_OVERLAP=0
# [OPTIONAL — default: 60]   Reciprocal Rank Fusion `k` parameter.
# RERANK_RRF_K=60
# [OPTIONAL]
# RERANK_MODEL=ms-marco-MiniLM-L-12-v2

# [OPTIONAL — default: 'chain']  chain = ConversationalRetrievalChain;
# langgraph = explicit graph pipeline.
RAG_ENGINE=chain


# -----------------------------------------------------------------------------
# 15. Web research / external search                                 [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL — default: false]  Enable the web-search tool.
WEB_RESEARCH_ENABLED=true
# [OPTIONAL — default: 'mock']  mock | tavily.
WEB_SEARCH_PROVIDER=mock
# [OPTIONAL — default: 5]
WEB_SEARCH_MAX_RESULTS=5
# Tavily example (requires `pip install tavily-python`):
# WEB_SEARCH_PROVIDER=tavily
# [REQUIRED IF WEB_SEARCH_PROVIDER=tavily]
# TAVILY_API_KEY=
# Note: Vue frontend has its own toggle in frontend-vue/.env.example
# (VITE_WEB_RESEARCH_ENABLED=true).


# -----------------------------------------------------------------------------
# 16. OAuth (Google / GitHub)                              [REQUIRED IF OAuth]
# -----------------------------------------------------------------------------
# [OPTIONAL — default: true in dev]
# AUTH_COOKIE_SECURE=true
# [OPTIONAL — default: 'lax']
# AUTH_COOKIE_SAMESITE=lax

# [REQUIRED IF using OAuth]  Local dev runs API on :8000 — Vue uses
# VITE_OAUTH_API_URL + /oauth/handoff. See docs/PRODUCTION_TLS.md.
# OAUTH_REDIRECT_BASE_URL=http://127.0.0.1:8000

# [REQUIRED IF using OAuth]  Comma-separated provider IDs.
# OAUTH_ENABLED_PROVIDERS=google,github
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=


# -----------------------------------------------------------------------------
# Test mode (used by `tox -e backend` via .env.test)                  [OPTIONAL]
# -----------------------------------------------------------------------------
# [OPTIONAL]
TESTING=false
# [OPTIONAL — default: false]   Internal flag set by pytest fixtures.
# TEST_MODE=false
# [OPTIONAL — default: false]   Top-level debug toggle.
# DEBUG=false


# -----------------------------------------------------------------------------
# Mock RAG demo (no cloud credentials needed)
# -----------------------------------------------------------------------------
# Uncomment to force the mock provider for both LLM and retriever.
# RAG_FORCE_MOCK=true
# LLM_PROVIDER=mock
# RETRIEVER_PROVIDER=mock
# DATABASE_URL=postgresql://chatbot:chatbot@localhost:5432/chatbot_dev
