# Copy to .env.local for local overrides (see frontend-vue/README.md)
VITE_API_URL=http://localhost:8000

# OAuth starts on API (session cookie); callback must match GitHub app
VITE_OAUTH_API_URL=http://127.0.0.1:8000

# Optional: mock the API in the browser during Vite dev (uses MSW)
# VITE_ENABLE_MSW=true

# Comma-separated: google,github (buttons hidden if empty)
VITE_OAUTH_PROVIDERS=

# Show web research toggle when server has WEB_RESEARCH_ENABLED=true (web-only path; not KB+web)
VITE_WEB_RESEARCH_ENABLED=true
