{
  "name": "chatbot-vue",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src --ext .ts,.vue --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "audit": "npm audit --audit-level=moderate",
    "prepare": "husky",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run coverage"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.2.3",
    "highlight.js": "^11.10.0",
    "lucide-vue-next": "^0.469.0",
    "markdown-it": "^14.1.0",
    "pinia": "^2.3.0",
    "radix-vue": "^1.9.9",
    "tailwind-merge": "^2.6.0",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0",
    "vue-sonner": "^1.2.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@pinia/testing": "^0.1.7",
    "@playwright/test": "^1.49.1",
    "@tailwindcss/vite": "^4.0.6",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/user-event": "^14.5.2",
    "@testing-library/vue": "^8.1.0",
    "@tsconfig/node20": "^20.1.9",
    "@types/dompurify": "^3.0.5",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.10.7",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vitest/coverage-v8": "^4.1.7",
    "@vue/eslint-config-typescript": "^14.2.0",
    "@vue/tsconfig": "^0.7.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.14.0",
    "eslint-plugin-vue": "^9.32.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.3.0",
    "msw": "^2.6.6",
    "tailwindcss": "^4.0.6",
    "typescript": "^5.7.3",
    "vite": "^6.4.2",
    "vitest": "^4.1.7",
    "vitest-axe": "^0.1.0",
    "vue-tsc": "^2.2.0"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=9.0.0"
  },
