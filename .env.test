# =============================================================================
# Campus RAG Assistant — test environment overrides
# =============================================================================
# Loaded automatically when APP_ENV=test (tox -e backend / tox -e eval set this).
# Mirrors the layout of .env.example so it stays easy to diff.
# =============================================================================


# -----------------------------------------------------------------------------
# 1. Core application                                                  [REQUIRED]
# -----------------------------------------------------------------------------
# [REQUIRED] Force the test config layer.
APP_ENV=test


# -----------------------------------------------------------------------------
# 2. Database (PostgreSQL)                                             [REQUIRED]
# -----------------------------------------------------------------------------
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=chatbot_test


# -----------------------------------------------------------------------------
# 3. API                                                               [REQUIRED]
# -----------------------------------------------------------------------------
API_URL=http://localhost:8000


# -----------------------------------------------------------------------------
# 7. RAG behaviour                                                   [OPTIONAL]
# -----------------------------------------------------------------------------
# Lower limits make unit tests faster and more deterministic.
MAX_TOKENS=100
TOP_K=10
TEMPERATURE=0.3
RETRIEVER_NUMBER_OF_RESULTS=6
RETRIEVER_SEARCH_TYPE=HYBRID


# -----------------------------------------------------------------------------
# 8. Logging                                                         [OPTIONAL]
# -----------------------------------------------------------------------------
LOGGING_LEVEL=INFO
LOGGING_FORMAT="%(asctime)s - %(name)s - %(levelname)s - %(message)s [in %(pathname)s:%(lineno)d]"
LOGGING_LOCATION=backend_logs.test.log
LOG_TO_FILE=true


# -----------------------------------------------------------------------------
# 9. LangSmith tracing                                               [OPTIONAL]
# -----------------------------------------------------------------------------
# Tracing OFF; the key is a dummy so SecretStr accepts it without errors.
LANGCHAIN_API_KEY=test-key
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=test-project


# -----------------------------------------------------------------------------
# Test mode                                                          [OPTIONAL]
# -----------------------------------------------------------------------------
TESTING=true
