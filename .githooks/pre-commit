#!/usr/bin/env bash
# Soft changelog reminder: warns (but never blocks) when staged code has no changelog update.
#
# Install: ./scripts/install-hooks.sh

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

YELLOW='\033[0;33m'
NC='\033[0m'

STAGED_CHANGELOG=$(git diff --cached --name-only | grep -E '^changelog/CHANGELOG\.md$' || true)
if [[ -n "$STAGED_CHANGELOG" ]]; then
  exit 0
fi

STAGED_CODE=$(git diff --cached --name-only | grep -Ev '^(docs/|\.env\.example|README\.md|changelog/CHANGELOG\.md)$' || true)
if [[ -z "$STAGED_CODE" ]]; then
  exit 0
fi

printf "\n${YELLOW}[changelog] Reminder:${NC} Update changelog/CHANGELOG.md [Unreleased] for this change.\n"
printf "  Or commit with --no-verify to skip.\n\n"
exit 0
