#!/usr/bin/env bash
# commit-msg — strip AI-tool authorship/attribution lines from commit messages.
#
# Delegates all logic to .githooks/tool_attribution_guard.py so the same
# implementation can be reused as a global hook
# (~/.config/git/hooks/commit-msg) and a Cursor preToolUse hook.
#
# Skip with: git commit --no-verify  (don't, unless you have a strong reason).

set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
  exit 0
fi

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GUARD="$HOOK_DIR/tool_attribution_guard.py"

if [[ ! -x "$GUARD" ]]; then
  # Guard missing — fail open: do not block commits if the script is gone.
  exit 0
fi

python3 "$GUARD" "$MSG_FILE"
